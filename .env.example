# App
NODE_ENV=development
APP_URL=http://localhost:3000
COOKIE_SECRET=           # 32 bytes random, base64 (genera con: openssl rand -base64 32)

# Database
# POSTGRES_PASSWORD lo lee podman-compose para inicializar el contenedor `db` y
# para construir DATABASE_URL en el servicio `app`. En local puede dejarse a
# "porra"; en PRODUCCIÓN genera uno fuerte (openssl rand -base64 24) y rota el
# usuario en la BD existente con ALTER USER (ver skill deploy-vps).
POSTGRES_PASSWORD=porra
DATABASE_URL=postgres://porra:porra@localhost:5432/porra

# Bootstrap (solo para crear el admin inicial; borra los valores tras el primer arranque)
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# Mundial 2026
TOURNAMENT_START_AT=2026-06-11T17:00:00Z   # cierre global de predicciones (MVP)
