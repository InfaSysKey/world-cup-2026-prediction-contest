# Mapeo nombre_fichero=email para infra/scripts/v2-apply.sh.
#
# Copia este archivo a porra-emails.local (en el mismo directorio del VPS) y
# rellena cada línea con el email REAL del usuario en la BD. El fichero
# porra-emails.local está gitignored: tus emails nunca entran al repo.
#
# Formato: una línea por archivo, "nombre.xlsx=email@dominio". Las líneas vacías
# y las que empiezan por `#` se ignoran.

Excel-Mundial-2026_Chambao.xlsx=chambao@example.com
Excel-Mundial-2026_Charli.xlsx=charli@example.com
Excel-Mundial-2026_Garrapto (1).xlsx=garrapto@example.com
Excel-Mundial-2026_Ivan.xlsx=ivan@example.com
Excel-Mundial-2026-Alber.xlsx=alber@example.com
Excel-Mundial-2026-PORRA-CARLOS.xlsx=carlos@porra.local
Excel-Mundial-2026-Ruben.xlsx=ruben@example.com
