# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

/porras-excel/*.xlsx

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright
/test-results/
/playwright-report/
/blob-report/
/.playwright/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
# Excels de las porras de los jugadores. NO suben al repo bajo ningún
# concepto (contienen predicciones personales).
porras-excel/*.xlsx
porras-excel/*.xls

# Mapeo de emails para v2-apply.sh: contiene direcciones reales de los
# usuarios. Solo se mantiene en el VPS, nunca en el repo.
infra/scripts/porra-emails.local

# Backups locales del VPS (formato pg_dump custom). Pueden subirse a B2 con
# backup-b2.sh pero no entran al repo.
infra/scripts/backups/*.dump
